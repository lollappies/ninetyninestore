{
  "rewrites": [
    {
      "source": "/((?!sitemap-main.xml|robots.txt|sitemap.xml|images|favicon.ico).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*).xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    }
  ]
}