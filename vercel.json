{
  "cleanUrls": false,

  "rewrites": [
    {
      "source": "/category/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/sale",
      "destination": "/index.html"
    }
  ],

  "headers": [
    {
      "source": "/sitemap-main.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    }
  ]
}